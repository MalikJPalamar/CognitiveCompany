# ============================================================
# Agent Workspace — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Memory (Graphiti + Neo4j) ---
GRAPHITI_URL=http://localhost:8000
NEO4J_PASSWORD=your-strong-password-here

# --- Vector DB (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001

# --- External Services ---
NOTION_TOKEN=secret_...
MONDAY_API_KEY=...
GITHUB_TOKEN=ghp_...
BRAVE_SEARCH_API_KEY=BSA...

# --- Trigger.dev (workflow orchestration) ---
TRIGGER_DEV_API_KEY=...
TRIGGER_SECRET_KEY=your-32-char-random-secret
TRIGGER_MAGIC_LINK_SECRET=your-32-char-random-secret
TRIGGER_ENCRYPTION_KEY=your-32-char-random-secret

# --- Database (Trigger.dev backing store) ---
POSTGRES_PASSWORD=your-strong-db-password
DATABASE_URL=postgresql://trigger:your-strong-db-password@localhost:5432/trigger_dev

# --- Deployment ---
VPS_HOST=your-vps-ip
VPS_USER=malik

# --- API Security ---
AGENT_API_KEY=your-api-key-for-nginx-auth

# --- Mem0 (optional managed alternative to Graphiti) ---
# MEM0_API_KEY=...
